# --- Server ---
PORT=8080
HOST=0.0.0.0
BASE_URL=https://newsletter.yourdomain.com
LOG_LEVEL=info

# --- Database ---
DB_PATH=/var/lib/based-newsletter/subscribers.db

# --- Mail driver: 'ses' or 'smtp' ---
MAIL_DRIVER=ses
MAIL_FROM=newsletter@yourdomain.com

# --- AWS SES (when MAIL_DRIVER=ses) ---
AWS_REGION=us-east-1
# Credentials via instance role or env:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- SMTP fallback (when MAIL_DRIVER=smtp) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Cron prune ---
PRUNE_AFTER_HOURS=48
